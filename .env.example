# LLM 提供方：anthropic（Claude 原生 tool_use）或 deepseek（默认，ReAct 文本）
LLM_PROVIDER=deepseek

# DeepSeek（deepseek 路径用）
DEEPSEEK_API_KEY=sk-你的DeepSeek_Key
LLM_BASE_URL=https://api.deepseek.com

# Claude / Anthropic（LLM_PROVIDER=anthropic 时用）
ANTHROPIC_API_KEY=sk-ant-你的Anthropic_Key
ANTHROPIC_MODEL=claude-opus-4-8

# OpenAI（备用，图片生成仍需要）
OPENAI_API_KEY=sk-proj-你的OpenAI_Key

# MCP Client — 外部 MCP Server 的认证信息
# GitHub MCP: https://github.com/settings/tokens → 勾选 repo/read:org
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_你的GitHub_Token
